# ============================================================================
# Supabase Configuration
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================================
# PostHog Configuration
# ============================================================================
POSTHOG_API_KEY=your-posthog-api-key
POSTHOG_API_HOST=https://app.posthog.com

# ============================================================================
# Email Configuration
# ============================================================================
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@example.com

# ============================================================================
# Background Jobs & Workflows
# ============================================================================
TRIGGER_API_KEY=your-trigger-dev-api-key
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook

# ============================================================================
# API Configuration
# ============================================================================
API_URL=http://localhost:3001
APP_URL=http://localhost:3000
API_SECRET=your-secret-key-for-signing

# ============================================================================
# Environment
# ============================================================================
NODE_ENV=development
NEXT_PUBLIC_ENVIRONMENT=development

# ============================================================================
# Analytics & Monitoring
# ============================================================================
DATADOG_API_KEY=your-datadog-api-key
SENTRY_DSN=your-sentry-dsn

# ============================================================================
# Feature Flags (can be overridden by PostHog)
# ============================================================================
FEATURE_FLAG_NOTIFICATION_SYSTEM_V2=false
FEATURE_FLAG_PERSONALIZED_FEED=false
FEATURE_FLAG_STREAMLINED_ONBOARDING=false

# ============================================================================
# Database
# ============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/engagement_engine
REDIS_URL=redis://localhost:6379

# ============================================================================
# Optional: AWS Services
# ============================================================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
SAGEMAKER_ENDPOINT=engagement-scoring

# ============================================================================
# Optional: Segment (CDP)
# ============================================================================
SEGMENT_WRITE_KEY=your-segment-write-key
SEGMENT_SPACE_ID=your-segment-space-id
